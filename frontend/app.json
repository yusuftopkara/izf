{
  "expo": {
    "name": "IZF Zumba",
    "slug": "izf-zumba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "izf-zumba",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.izf.zumba",
      "infoPlist": {
        "NSCameraUsageDescription": "QR kod taramak için kamera erişimi gerekli",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı ve paylaşımlar için galeri erişimi",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.izf.zumba",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "splash": {
        "image": "./assets/images/splash-web.png",
        "resizeMode": "contain",
        "backgroundColor": "#1E1432"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#1E1432"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B6B",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod taramak için kamera erişimi gerekli"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
